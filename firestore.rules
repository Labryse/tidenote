rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /notes/{noteId} {
      // Public notes can be read by anyone; private notes only by their owner
      allow read: if resource.data.isPublic == true
                  || (request.auth != null && resource.data.ownerId == request.auth.uid);

      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;

      // Allow create only if user is logged in and sets themselves as the owner
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;

      // Canvas image files: same access as the parent note. Read follows the
      // note's public/owner rule (so shared notes render); writes are owner-only.
      match /files/{fileId} {
        function parent() {
          return get(/databases/$(database)/documents/notes/$(noteId)).data;
        }
        allow read: if parent().isPublic == true
                    || (request.auth != null && parent().ownerId == request.auth.uid);
        allow write: if request.auth != null && parent().ownerId == request.auth.uid;
      }
    }

    match /users/{userId}/folders/{folderId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/collections/{collectionId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
