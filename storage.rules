rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Canvas note images. Public read is intentional: public/shared canvas notes
    // embed these files and are viewed unauthenticated. Only the owner may write,
    // limited to images under 10 MB.
    match /canvas-files/{uid}/{noteId}/{fileId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
